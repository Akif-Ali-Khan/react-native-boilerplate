{
  "name": "rntemplate",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Akif Ali Khan",
    "email": "dev.akifalikhan@gmail.com"
  },
  "scripts": {
    "android": "react-native run-android --active-arch-only",
    "ios": "react-native run-ios",
    "start": "watchman watch-del-all && react-native start --reset-cache",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typescript": "tsc --project tsconfig.json --noEmit",
    "prettier": "prettier src --check",
    "prepare": "husky install",
    "postinstall": "yarn android-clean && yarn ios-pod-install",
    "android-clean": "cd android && ./gradlew clean && cd ..",
    "ios-pod-install": "cd ios && bundle install && bundle exec pod install && cd .."
  },
  "dependencies": {
    "@react-native-community/geolocation": "^3.0.3",
    "@react-navigation/native": "^6.0.13",
    "@reduxjs/toolkit": "^1.9.0",
    "@shopify/flash-list": "^1.3.1",
    "axios": "^1.1.3",
    "react": "18.2.0",
    "react-native": "0.70.6",
    "react-native-bootsplash": "^4.3.2",
    "react-native-config": "^1.4.11",
    "react-native-fast-image": "^8.6.3",
    "react-native-image-crop-picker": "^0.38.1",
    "react-native-localize": "^2.2.4",
    "react-native-mmkv-storage": "^0.8.0",
    "react-native-paper": "4.12.5",
    "react-native-permissions": "^3.6.1",
    "react-native-safe-area-context": "^4.4.1",
    "react-native-screens": "^3.18.2",
    "react-native-shimmer-placeholder": "^2.0.9",
    "react-native-vector-icons": "^9.2.0",
    "react-redux": "^8.0.5",
    "redux": "^4.2.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/runtime": "^7.20.1",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/jest-native": "^5.1.2",
    "@testing-library/react-native": "^11.4.0",
    "@tsconfig/react-native": "^2.0.2",
    "@types/jest": "^29.2.2",
    "@types/react-native": "^0.70.6",
    "@types/react-redux": "^7.1.24",
    "@types/react-test-renderer": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "axios-mock-adapter": "^1.21.2",
    "babel-jest": "^29.2.2",
    "babel-plugin-module-resolver": "^4.1.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "detox": "^19.12.6",
    "eslint": "^8.26.0",
    "eslint-plugin-react": "^7.31.11",
    "husky": "^8.0.0",
    "jest": "^29.2.2",
    "metro-react-native-babel-preset": "0.73.3",
    "prettier": "^2.8.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^4.8.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
